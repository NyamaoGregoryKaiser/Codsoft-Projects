```
# Application Configuration
APP_PORT=8080
APP_ENV=development

# Database Configuration
DATABASE_PATH=./data/auth_system.db

# JWT Configuration
JWT_SECRET=supersecretjwtkeythatshouldbemorethan256bitlongandrandomlygeneratedinproduction
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600 # 1 hour
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=2592000 # 30 days

# Logging Configuration
LOG_LEVEL=INFO # DEBUG, INFO, WARN, ERROR, FATAL

# Rate Limiting Configuration (conceptual)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60

# Caching Configuration (conceptual)
CACHING_ENABLED=false
CACHE_REDIS_HOST=localhost
CACHE_REDIS_PORT=6379
```