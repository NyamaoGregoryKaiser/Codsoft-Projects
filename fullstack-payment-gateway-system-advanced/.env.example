```
APP_ENV=development

# Database
DATABASE_URL="postgresql+psycopg2://user:password@db:5432/payment_processor"

# JWT Secret (generate a strong one: openssl rand -hex 32)
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_HOURS=24

# Redis
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_DB=0

# Admin User Defaults (for initial setup)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin_password"

# Mock Payment Gateway Settings
MOCK_GATEWAY_SUCCESS_RATE=0.9
MOCK_GATEWAY_PROCESSING_DELAY_SECONDS=2
```