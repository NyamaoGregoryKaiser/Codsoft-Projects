```
# Database Configuration
DB_NAME=taskflow_db
DB_USER=taskflow_user
DB_PASSWORD=taskflow_password

# JWT Secret (should be a long, random string in production)
JWT_SECRET=aVerySecretKeyThatIsAtLeast256BitsLongAndShouldBeChangedInProduction

# Grafana Admin Credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Backend Host for Frontend build (if not running on same host network)
# Default for Docker Compose is 'localhost' if host machine, or service name 'backend' if from another container.
# If running frontend directly on host, use 'localhost'. If frontend in container, use 'backend'.
# For local dev without docker-compose for frontend, use http://localhost:8080/api
# For docker-compose, this is used in Dockerfile.frontend, it will resolve to 'backend' service name
BACKEND_HOST=backend
```