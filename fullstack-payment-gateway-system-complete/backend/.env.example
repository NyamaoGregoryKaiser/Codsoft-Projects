# Application
APP_PORT=3000
APP_ENV=development # development, production, test

# Database
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=payment_system_db

# JWT Authentication
JWT_SECRET=supersecretjwtkey # CHANGE THIS IN PRODUCTION
JWT_EXPIRATION_TIME=3600s # e.g., 3600s, 7d, 24h

# Redis Cache & Rate Limiting
REDIS_HOST=localhost
REDIS_PORT=6379

# Logging
LOG_LEVEL=info # debug, info, warn, error
LOG_DIR=logs
LOG_MAX_FILES=7d # Retain logs for 7 days

# Payment Gateway (Simulated)
# In a real system, these would be API keys for Stripe, PayPal, etc.
PAYMENT_GATEWAY_API_KEY=mock_api_key
PAYMENT_GATEWAY_SECRET=mock_secret

# Webhooks
WEBHOOK_SIGNING_SECRET=webhook_secret_for_validation # Secret for signing outgoing webhooks

# Throttler (Rate Limiting)
THROTTLER_TTL=60 # seconds
THROTTLER_LIMIT=10 # requests per TTL