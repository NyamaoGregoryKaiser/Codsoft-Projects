// Example: backend/src/models/models.controller.ts (applying CacheInterceptor)
import { Controller, Get, Post, Body, Patch, Param, Delete, UseGuards, CacheInterceptor, UseInterceptors } from '@nestjs/common';
import { ModelsService } from './models.service';
import { CreateModelDto } from './dto/create-model.dto';
import { UpdateModelDto } from './dto/update-model.dto';
import { JwtAuthGuard } from '../auth/jwt-auth.guard';
import { RolesGuard } from '../common/guards/roles.guard';
import { Roles } from '../common/decorators/roles.decorator';
import { Role } from '../common/enums/role.enum';
import { ApiBearerAuth, ApiOperation, ApiResponse, ApiTags } from '@nestjs/swagger';

@ApiTags('models')
@ApiBearerAuth('access-token')
@Controller('api/models')
@UseGuards(JwtAuthGuard, RolesGuard)
export class ModelsController {
  constructor(private readonly modelsService: ModelsService) {}

  @Post()
  @Roles(Role.Admin, Role.User)
  @ApiOperation({ summary: 'Create a new ML model' })
  @ApiResponse({ status: 201, description: 'The model has been successfully created.' })
  @ApiResponse({ status: 403, description: 'Forbidden.' })
  create(@Body() createModelDto: CreateModelDto) {
    return this.modelsService.create(createModelDto);
  }

  @Get()
  @Roles(Role.Admin, Role.User)
  @UseInterceptors(CacheInterceptor) // Cache this endpoint's response
  @ApiOperation({ summary: 'Get all ML models' })
  @ApiResponse({ status: 200, description: 'Return all models.' })
  findAll() {
    return this.modelsService.findAll();
  }

  @Get(':id')
  @Roles(Role.Admin, Role.User) // A user can view their own models
  @UseInterceptors(CacheInterceptor) // Cache individual model fetches
  @ApiOperation({ summary: 'Get an ML model by ID' })
  @ApiResponse({ status: 200, description: 'Return a single model.' })
  @ApiResponse({ status: 404, description: 'Model not found.' })
  findOne(@Param('id') id: string) {
    return this.modelsService.findOne(id);
  }

  // ... other CRUD operations
}
