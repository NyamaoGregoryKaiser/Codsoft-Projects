# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=authuser
DB_PASSWORD=authpassword
DB_NAME=authdb

# JWT Configuration
# IMPORTANT: Generate strong, random secrets for production!
JWT_SECRET=your_super_secret_jwt_key_for_access_tokens_12345
JWT_REFRESH_SECRET=your_super_secret_jwt_key_for_refresh_tokens_67890
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_MINUTES=1440 # 24 hours

# Server Configuration
HTTP_PORT=9080

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60