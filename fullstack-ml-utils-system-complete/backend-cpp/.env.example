# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8080
APP_WORKERS=4 # Number of threads for Crow

# Database Configuration (PostgreSQL)
DB_HOST=ml_db # Service name in docker-compose
DB_PORT=5432
DB_NAME=ml_system_db
DB_USER=ml_user
DB_PASSWORD=ml_password
DB_POOL_SIZE=10 # Number of connections in the pool

# JWT Configuration
JWT_SECRET=super_secret_jwt_key_that_should_be_long_and_random_in_production
JWT_EXPIRATION_HOURS=24

# Logging Configuration
LOG_LEVEL=info # trace, debug, info, warn, error, critical
LOG_FILE_PATH=./logs/ml_backend.log

# Caching Configuration
CACHE_TTL_SECONDS=300 # Time-to-live for cached items in seconds (e.g., 5 minutes)

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60 # Max requests per window
```