NODE_ENV=development
PORT=5000

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=cms_user
DB_PASSWORD=cms_password
DB_NAME=cms_db

# JWT Secret
JWT_SECRET=supersecretjwtkeythatshouldbemorecomplexinproduction
JWT_EXPIRES_IN=1d

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# File Uploads
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880 # 5MB

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100