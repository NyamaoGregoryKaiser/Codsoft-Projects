# Node.js Environment
NODE_ENV=development # or production, test
PORT=5000

# Database Configuration (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_USER=perfmonuser
DB_PASSWORD=perfmonpassword
DB_NAME=perfmondb

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_for_prod
JWT_EXPIRES_IN=1d

# API Key Secret (for hashing/validation - if storing hashed API keys)
API_KEY_SECRET=your_api_key_secret_key_here_for_prod

# Caching
CACHE_TTL=300 # seconds for cached responses

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000       # 1 minute
RATE_LIMIT_MAX_REQUESTS=100      # 100 requests per minute for general APIs
PERF_DATA_RATE_LIMIT_MAX_REQUESTS=1000 # 1000 requests per minute for performance data ingestion

# Frontend Environment
REACT_APP_API_BASE_URL=http://localhost:5000/api