```ini
# Backend Configuration
FLASK_APP=backend/app/app.py
FLASK_ENV=development
SECRET_KEY=a_very_secret_key_that_should_be_long_and_random_in_production
DATABASE_URL=postgresql://user:password@db:5432/dboptiflow_db
REDIS_URL=redis://redis:6379/0

# JWT Configuration
JWT_SECRET_KEY=another_very_secret_key_for_jwt_in_production
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# Frontend Configuration (used in Dockerfile.frontend during build)
REACT_APP_API_BASE_URL=/api

# Database connection details for external databases (example, these are stored in DBOptiFlow's DB)
# EXT_DB_HOST=localhost
# EXT_DB_PORT=5432
# EXT_DB_USER=ext_user
# EXT_DB_PASSWORD=ext_password
# EXT_DB_NAME=external_db
```