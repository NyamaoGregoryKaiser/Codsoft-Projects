```
PORT=5000
NODE_ENV=development

# Database Configuration
DB_NAME=scraperhub_db
DB_USER=scraperhub_user
DB_PASS=scraperhub_password
DB_HOST=db
DB_PORT=5432
DATABASE_URL="postgres://scraperhub_user:scraperhub_password@db:5432/scraperhub_db"

# JWT Secret
JWT_SECRET=supersecretjwtkeythatshouldbemorecomplexinprod
JWT_EXPIRES_IN=1h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Puppeteer Options (optional, for custom browser path etc.)
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=new
```