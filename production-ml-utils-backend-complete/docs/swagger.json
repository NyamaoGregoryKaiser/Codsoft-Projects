      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["user", "admin"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "email", "role"]
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "owner": { "$ref": "#/components/schemas/User" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "owner"]
      },
      "Dataset": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "filePath": { "type": "string" },
          "fileSize": { "type": "number" },
          "mimeType": { "type": "string" },
          "projectId": { "type": "string", "format": "uuid" },
          "ownerId": { "type": "string", "format": "uuid" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "filePath", "fileSize", "mimeType", "projectId", "ownerId"]
      },
      "Model": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "filePath": { "type": "string" },
          "fileSize": { "type": "number" },
          "mimeType": { "type": "string" },
          "projectId": { "type": "string", "format": "uuid" },
          "ownerId": { "type": "string", "format": "uuid" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "version", "filePath", "fileSize", "mimeType", "projectId", "ownerId"]
      },
      "Experiment": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] },
          "parameters": { "type": "object" },
          "metrics": { "type": "object" },
          "projectId": { "type": "string", "format": "uuid" },
          "modelId": { "type": "string", "format": "uuid", "nullable": true },
          "datasetId": { "type": "string", "format": "uuid", "nullable": true },
          "ownerId": { "type": "string", "format": "uuid" },
          "startTime": { "type": "string", "format": "date-time", "nullable": true },
          "endTime": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "status", "projectId", "ownerId"]
      },
      "Error": {
        "type": "object",
        "properties": {
