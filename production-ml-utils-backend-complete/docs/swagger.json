```json
{
  "openapi": "3.0.0",
  "info": {
    "title": "ML Utilities System API",
    "version": "1.0.0",
    "description": "API for managing ML projects, datasets, models, and experiments."
  },
  "servers": [
    {
      "url": "/api/v1",
