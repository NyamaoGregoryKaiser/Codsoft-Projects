```ini
# Core Application Settings
APP_NAME="ML-Toolbox Backend"
API_V1_STR=/api/v1

# Database Settings
POSTGRES_SERVER=db
POSTGRES_USER=ml_user
POSTGRES_PASSWORD=ml_password
POSTGRES_DB=ml_db

# JWT Settings
SECRET_KEY="YOUR_SUPER_SECRET_KEY_REPLACE_ME_IN_PROD_DANGER_DANGER"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis Cache Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# File Storage
UPLOAD_DIRECTORY="/app/data/uploads" # Inside Docker container
MODEL_DIRECTORY="/app/data/models"   # Inside Docker container

# Environment (e.g., development, production, testing)
ENVIRONMENT=development
```