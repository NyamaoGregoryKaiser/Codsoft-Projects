```
# Application Configuration
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY="your_super_secret_key_here_at_least_32_chars" # Replace in production!
JWT_SECRET_KEY="your_jwt_secret_key_here_at_least_32_chars" # Replace in production!
DEBUG=True

# Database Configuration
DATABASE_URL="postgresql://user:password@db:5432/vizcraft_db"

# Redis Configuration (for Caching and Rate Limiting)
REDIS_URL="redis://redis:6379/0"
CACHE_TYPE="redis" # alternatives: 'simple', 'filesystem'

# Rate Limiting Configuration
RATELIMIT_STORAGE_URL="redis://redis:6379/1" # Separate DB for rate limiting

# CORS Configuration (adjust for production frontend URL)
CORS_ORIGINS="http://localhost:3000,http://localhost:8080" # Comma-separated
CORS_SUPPORTS_CREDENTIALS=True

# Logging Configuration
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH=/var/log/vizcraft/app.log

# Admin User (for seeding)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword
ADMIN_EMAIL=admin@vizcraft.com
```