# Django Settings
DEBUG=True
SECRET_KEY=your_development_secret_key # IMPORTANT: Change this in production
ALLOWED_HOSTS=['localhost', '127.0.0.1'] # Add your production domains

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgres://user:password@db:5432/mydatabase

# Redis for Caching and Celery Broker
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Optional: Email settings for Django (e.g., for password reset)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=YOUR_SENDGRID_API_KEY
# DEFAULT_FROM_EMAIL=your_app@example.com
