// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum RecommendationStatus {
  PENDING
  APPROVED
  IMPLEMENTED
  DISMISSED
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  firstName        String?
  lastName         String?
  role             UserRole          @default(USER)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  analysisReports  AnalysisReport[]
  recommendations  Recommendation[]
  targetDatabases  TargetDatabase[]
}

model TargetDatabase {
  id               String            @id @default(uuid())
  name             String
  type             String // e.g., "PostgreSQL", "MySQL", "MongoDB"
  connectionString String?
  description      String?
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  analysisReports  AnalysisReport[]
  recommendations  Recommendation[]
}

model AnalysisReport {
  id               String            @id @default(uuid())
  title            String
  description      String?
  reportDate       DateTime          @default(now())
  targetDatabaseId String
  targetDatabase   TargetDatabase    @relation(fields: [targetDatabaseId], references: [id])
  analystId        String
  analyst          User              @relation(fields: [analystId], references: [id])
  slowQueries      Json?             // Store an array of slow query details (e.g., query, executionTime, count)
  recommendations  Recommendation[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Recommendation {
  id               String                 @id @default(uuid())
  title            String
  description      String
  status           RecommendationStatus   @default(PENDING)
  priority         Int                    @default(0) // 0: Low, 1: Medium, 2: High
  analysisReportId String
  analysisReport   AnalysisReport         @relation(fields: [analysisReportId], references: [id])
  targetDatabaseId String
  targetDatabase   TargetDatabase         @relation(fields: [targetDatabaseId], references: [id])
  recommendedById  String
  recommendedBy    User                   @relation(fields: [recommendedById], references: [id])
  assignedToId     String?
  assignedTo       User?                  @relation("AssignedTo", fields: [assignedToId], references: [id])
  implementationDetails Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
}
