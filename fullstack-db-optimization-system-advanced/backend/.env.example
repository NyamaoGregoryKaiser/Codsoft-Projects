NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/optimizer_db?schema=public"
JWT_SECRET=supersecretjwtkey
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=supersecretrefreshkey
REFRESH_TOKEN_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info # debug, http, info, warn, error
CACHE_TTL_SECONDS=3600 # Cache time-to-live for data, e.g., 1 hour
COLLECTOR_SCHEDULE_CRON="0 */1 * * *" # Every hour, for metric collection
SLOW_QUERY_THRESHOLD_MS=500