POSTGRES_DB=optimizer_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_for_dev

# Backend Specific
NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://postgres:postgres_password_for_dev@db:5432/optimizer_db?schema=public"
JWT_SECRET=supersecretjwtkey
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=supersecretrefreshkey
REFRESH_TOKEN_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info
CACHE_TTL_SECONDS=3600
COLLECTOR_SCHEDULE_CRON="*/5 * * * *" # Every 5 minutes for demo
SLOW_QUERY_THRESHOLD_MS=500

# Frontend Specific
REACT_APP_API_URL=http://localhost:5000/api
```

