# Node.js Environment
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001 # URL where your frontend is running

# Database Configuration (PostgreSQL)
# Example: postgres://user:password@host:port/database
DATABASE_URL=postgres://nestjs_chat_user:password@localhost:5432/nestjs_chat_db

# JWT Authentication
JWT_SECRET=supersecretjwtkey # CHANGE THIS IN PRODUCTION
JWT_EXPIRES_IN=1h

# Redis for Caching/Session Store
REDIS_HOST=localhost
REDIS_PORT=6379
SESSION_SECRET=supersecretsessionkey # CHANGE THIS IN PRODUCTION

# Logging Configuration
LOG_LEVEL=debug # debug, info, warn, error
LOGS_DIR=./logs

# Rate Limiting (per IP per minute)
THROTTLE_TTL=60 # seconds
THROTTLE_LIMIT=10 # requests

```