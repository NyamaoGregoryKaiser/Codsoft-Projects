```
DATABASE_URL="postgresql+psycopg2://user:password@db:5432/web_scraper_db"
SECRET_KEY="your-super-secret-key-please-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080 # 7 days
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin_password" # Change this in production
LOG_LEVEL="INFO"
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_DEFAULT="5/minute" # Default rate limit for unauthenticated users or specific endpoints
```