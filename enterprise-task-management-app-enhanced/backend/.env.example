# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=password
DB_DATABASE=taskmanager_db
SYNCHRONIZE_DB=false # Set to true for development, false for production (use migrations)
LOGGING_DB=false

# JWT Authentication
JWT_SECRET=superSecretKeyForDev
JWT_EXPIRATION_TIME=3600s # 1 hour

# Caching (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=300 # 5 minutes

# Rate Limiting
THROTTLE_TTL=60 # 60 seconds
THROTTLE_LIMIT=100 # 100 requests