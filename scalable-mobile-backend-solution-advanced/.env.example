```ini
# Core Application Settings
APP_PORT=8080
APP_THREADS=4
APP_NAME="MobileBackend"
APP_JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY_HERE_CHANGE_ME_IN_PROD"
APP_LOG_LEVEL="info" # trace, debug, info, warn, error, critical, off

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=mobile_user
DB_PASSWORD=mobile_password
DB_NAME=mobile_backend_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD="" # Optional, if Redis requires a password
REDIS_DB_INDEX=0

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
```