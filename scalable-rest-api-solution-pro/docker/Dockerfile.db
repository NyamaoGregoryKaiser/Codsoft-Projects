```dockerfile
# Dockerfile for PostgreSQL Database
FROM postgres:15-alpine

# Set environment variables for PostgreSQL
ENV POSTGRES_DB=project_management_db
ENV POSTGRES_USER=appuser
ENV POSTGRES_PASSWORD=password
ENV PGDATA=/var/lib/postgresql/data/pgdata

# Expose the PostgreSQL port
EXPOSE 5432

# Create the directory for PGDATA
RUN mkdir -p ${PGDATA}
VOLUME ${PGDATA}

# Optional: Copy initialization scripts
# COPY ./database/init_pg.sh /docker-entrypoint-initdb.d/
# COPY ./database/migrations/*.sql /docker-entrypoint-initdb.d/
# COPY ./database/seed/*.sql /docker-entrypoint-initdb.d/
```