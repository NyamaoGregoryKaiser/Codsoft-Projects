```
# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=9080
SERVER_THREADS=4

# Database Configuration (for SQLite development)
# For PostgreSQL in production, use:
# DB_PATH="postgresql://user:password@host:port/dbname"
DB_PATH=database/project_management.db

# JWT Configuration
JWT_SECRET=supersecretjwtkey_changeme_in_production!
JWT_ISSUER=project-management-api
JWT_EXPIRY_MINUTES=60 # Token expiry in minutes

# Rate Limiting Configuration
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_TIME_WINDOW_SECONDS=60 # in seconds

# Logging Configuration
LOG_CONFIG_PATH=config/log_config.json
```