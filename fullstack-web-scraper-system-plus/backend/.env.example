# Server Configuration
PORT=5000
NODE_ENV=development # development, production, test

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=scraperuser
DB_PASSWORD=scraperpassword
DB_NAME=web_scraper_db
DB_SSL=false # Set to true for production with SSL, e.g., on Heroku

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production_seriously
JWT_EXPIRES_IN=1d

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Puppeteer Configuration
PUPPETEER_HEADLESS=new # true, false, 'new'
PUPPETEER_EXECUTABLE_PATH= # Optional: path to Chrome/Chromium executable, e.g., /usr/bin/google-chrome

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000