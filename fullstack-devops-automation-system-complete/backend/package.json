{
  "name": "product-catalog-backend",
  "version": "1.0.0",
  "description": "Backend for Product Catalog Management System",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- -d src/database/data-source.ts migration:generate src/database/migrations/$(date +%Y%m%d%H%M%S)-",
    "migration:create": "npm run typeorm -- -d src/database/data-source.ts migration:create src/database/migrations/",
    "migration:run": "npm run typeorm -- -d src/database/data-source.ts migration:run",
    "migration:revert": "npm run typeorm -- -d src/database/data-source.ts migration:revert",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeds/seed.ts",
    "test": "jest --detectOpenHandles --forceExit --coverage --maxWorkers=1",
    "test:watch": "jest --watch --detectOpenHandles --forceExit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
