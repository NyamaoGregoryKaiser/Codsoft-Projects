NODE_ENV=development
PORT=5000

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ml_user
DB_PASSWORD=ml_password
DB_DATABASE=ml_utilities_db

# JWT Configuration
JWT_SECRET=supersecretjwtkey
JWT_EXPIRES_IN=1h

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100