```ini
# --- OptiDB System Database Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=optidb
DB_USER=optidb_user
DB_PASSWORD=optidb_password

# --- JWT Configuration ---
# IMPORTANT: Generate a strong, random secret for production.
# Example: openssl rand -base64 32
JWT_SECRET=super_secret_jwt_key_that_should_be_long_and_random
JWT_EXPIRY_SECONDS=3600 # Token expiry in seconds (1 hour)

# --- Server Configuration ---
SERVER_PORT=18080

# --- Logging Configuration ---
# Options: TRACE, DEBUG, INFO, WARN, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# --- Target DB Connection Configuration ---
# Timeout for OptiDB trying to connect to a target database (in milliseconds)
TARGET_DB_CONN_TIMEOUT_MS=5000
# Max concurrent connections OptiDB will attempt to target databases (global limit)
TARGET_DB_MAX_CONN=5

# --- Security Notes ---
# Passwords for target databases are stored encrypted in OptiDB's DB.
# For the encryption/decryption (Crypto++ in this example), keys and IVs
# are currently hardcoded in src/services/target_db_service.cpp.
# IN PRODUCTION, THESE MUST BE SECURELY MANAGED (e.g., AWS KMS, Azure Key Vault, HashiCorp Vault)
# and passed as environment variables or mounted secrets.
# Hardcoded keys are for DEMONSTRATION PURPOSES ONLY.
```