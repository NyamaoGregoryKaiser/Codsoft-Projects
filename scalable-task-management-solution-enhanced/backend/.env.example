PROJECT_NAME="Task Management System"
API_V1_STR=/api/v1

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database (PostgreSQL)
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=task_db
# Optional: DATABASE_URL="postgresql+asyncpg://user:password@host:port/dbname"

# JWT Authentication
SECRET_KEY="YOUR_SUPER_SECRET_KEY_REPLACE_ME_WITH_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300

# CORS origins (comma-separated, no trailing slash)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Redis for Caching & Rate Limiting
REDIS_URL="redis://redis:6379/0"

# Initial Superuser (for seeding)
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=supersecret
FIRST_SUPERUSER_USERNAME=admin

LOG_LEVEL=INFO