# --- Core Django Settings ---
DEBUG=True
SECRET_KEY=your_insecure_dev_key_change_in_prod
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database Settings (PostgreSQL recommended) ---
DATABASE_URL=postgres://user:password@db:5432/cms_db

# --- Redis Settings (for Caching & Celery) ---
REDIS_URL=redis://redis:6379/0

# --- Production Specific Settings (Uncomment and set for production) ---
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_BROWSER_XSS_FILTER=True
# SECURE_CONTENT_TYPE_NOSNIFF=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# --- Admin URL (change for production security) ---
# ADMIN_URL=super-secret-admin-path/