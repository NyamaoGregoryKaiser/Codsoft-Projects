```dotenv
# Node Environment
NODE_ENV=development
PORT=5000

# Database Configuration (PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@db:5432/data_viz_db

# JWT Secret and Expiration
JWT_SECRET=your_jwt_secret_key_here # IMPORTANT: Change this to a strong, random key in production!
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your_refresh_secret_key_here # IMPORTANT: Change this to a strong, random key in production!
REFRESH_TOKEN_EXPIRES_IN=7d

# Caching Configuration
ENABLE_CACHE=true
CACHE_TTL=3600 # seconds

# Rate Limiting Configuration
RATE_LIMIT_WINDOW=60 # seconds
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
FRONTEND_URL=http://localhost:3000
```