# FastAPI Application Settings
FASTAPI_ENV=development # development or production
PROJECT_NAME="Project Management System"
API_V1_STR=/api/v1

# Database Settings (PostgreSQL)
# For local Docker Compose, use 'db' as hostname
DATABASE_URL="postgresql+asyncpg://user:password@db:5432/app_db"
# Example for local machine without Docker: "postgresql+asyncpg://user:password@localhost:5432/app_db"

# JWT Authentication Settings
SECRET_KEY="YOUR_SUPER_SECRET_KEY_GOES_HERE_CHANGE_THIS_IN_PRODUCTION"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60 # Token expiry in minutes

# Redis Cache and Rate Limiting Settings
# For local Docker Compose, use 'redis' as hostname
REDIS_URL="redis://redis:6379/0"
# Example for local machine without Docker: "redis://localhost:6379/0"

# Rate Limiting Configuration (requests per duration)
RATE_LIMIT_CALLS=5
RATE_LIMIT_PERIOD_SECONDS=10 # 5 calls every 10 seconds

# Frontend Settings (React)
REACT_APP_API_BASE_URL="http://localhost:8000"
```