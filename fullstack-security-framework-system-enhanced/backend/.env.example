NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/secure_app_db?schema=public"

# JWT
JWT_SECRET=supersecretjwtkey
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_COOKIE_NAME_ACCESS=accessToken
JWT_COOKIE_NAME_REFRESH=refreshToken

# CORS
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Rate Limiting
REDIS_HOST=localhost
REDIS_PORT=6379
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # 100 requests per window

# Cache
CACHE_TTL_SECONDS=3600 # 1 hour

# Email (for password reset - for demo, we log to console)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_FROM=noreply@yourdomain.com
RESET_PASSWORD_URL=http://localhost:3000/reset-password