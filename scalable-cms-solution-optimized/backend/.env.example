NODE_ENV=development
PORT=5000

# Database Configuration (PostgreSQL)
DB_USERNAME=cms_user
DB_PASSWORD=cms_password
DB_DATABASE=cms_dev_db
DB_HOST=localhost
DB_PORT=5432
# For production, consider using a connection string or more secure variable names
# For Test DB (used by Jest)
TEST_DB_USERNAME=cms_user
TEST_DB_PASSWORD=cms_password
TEST_DB_DATABASE=cms_test_db
TEST_DB_HOST=localhost
TEST_DB_PORT=5432

# JWT Secret (should be a long, random string in production)
JWT_SECRET=supersecretjwtkeyforCMS!
JWT_EXPIRES_IN=1h

# Bcrypt Salt Rounds (cost factor for hashing, higher is more secure but slower)
BCRYPT_SALT_ROUNDS=10

# Caching
CACHE_TTL=300 # In seconds (5 minutes)

# CORS (Frontend URL allowed to access this backend)
FRONTEND_URL=http://localhost:3000

# Enable/Disable database migrations on startup in production (default false)
APPLY_MIGRATIONS=false
```