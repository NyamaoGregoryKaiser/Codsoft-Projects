# Global environment variables for docker-compose
# These will be passed to services as needed

# Database (PostgreSQL)
DB_USERNAME=cms_user
DB_PASSWORD=cms_password
DB_DATABASE=cms_dev_db
# DB_HOST is 'localhost' for direct connection or 'db' when inside docker-compose network
DB_PORT=5432

# Backend specific
JWT_SECRET=supersecretjwtkeyforCMS!
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=10
CACHE_TTL=300

# Frontend specific
# REACT_APP_API_BASE_URL is set directly in docker-compose.yml based on service connectivity
```