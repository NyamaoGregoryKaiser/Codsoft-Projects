```
# --- General Settings ---
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE" # Generate a strong random key
PROJECT_NAME="E-commerce API"
API_V1_STR="/api/v1"
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 7 days

# --- Database Settings (PostgreSQL) ---
POSTGRES_SERVER="db" # Service name in docker-compose
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="ecommerce_db"
DATABASE_PORT=5432

# --- Superuser Credentials (for initial setup) ---
FIRST_SUPERUSER_EMAIL="admin@example.com"
FIRST_SUPERUSER_PASSWORD="adminpassword" # Strong password for admin

# --- CORS Origins (comma-separated, e.g., "http://localhost:3000,http://frontend.example.com") ---
# For Docker setup, frontend will be at http://localhost:8001
BACKEND_CORS_ORIGINS='["http://localhost:8001", "http://127.0.0.1:8001"]'

# --- Redis Settings ---
REDIS_SERVER="redis" # Service name in docker-compose
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD="your_redis_password" # Uncomment and set if Redis requires authentication
```