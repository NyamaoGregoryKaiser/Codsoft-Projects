# Node Environment
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public" # e.g., postgresql://myuser:mypassword@db:5432/mydatabase?schema=public

# JWT Authentication
JWT_SECRET="supersecretjwtkey" # CHANGE THIS IN PRODUCTION
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# Redis Cache
REDIS_URL="redis://localhost:6379" # e.g., redis://redis:6379
CACHE_TTL_SECONDS=3600 # Default cache time-to-live for API responses (1 hour)

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per minute per IP

# Logging
LOG_LEVEL=info # debug, info, warn, error
```