## 6. Additional Features

*   **Authentication/Authorization**: Implemented using JWT via `jwt-cpp` and middleware (`auth_middleware.hpp`). Roles (`admin`, `customer`) are supported for fine-grained access.
*   **Logging and Monitoring**: `spdlog` for structured logging. Docker Compose includes volume mapping for logs. Mentions Prometheus/Grafana for monitoring in `DEPLOYMENT.md`.
*   **Error Handling Middleware**: Demonstrated a basic `handleApiError` helper in `routes.cpp` for consistent JSON error responses and status codes. A more advanced setup might use a global exception handler or specific error classes.
*   **Caching Layer**: `src/utils/cache_manager.hpp/cpp` is a placeholder. For a true production system, this would integrate with Redis (as indicated in `docker-compose.yml` and `.env.example`).
    *   Example `src/utils/cache_manager.hpp`:
        ```cpp
        #ifndef ZENITH_CACHE_MANAGER_HPP
        #define ZENITH_CACHE_MANAGER_HPP

        #include <string>
        #include <optional>
        #include <map> // Simple in-memory cache for demonstration
        #include <mutex>

        namespace Zenith {
        namespace Utils {

        class CacheManager {
        public:
            static CacheManager& getInstance();

            // Store a value with optional expiration (in seconds)
            void set(const std::string& key, const std::string& value, long ttl_seconds = 0);

            // Retrieve a value
            std::optional<std::string> get(const std::string& key);

            // Remove a value
            void remove(const std::string& key);

            // Clear all cache (for testing or specific scenarios)
            void clear();

        private:
            CacheManager();
            CacheManager(const CacheManager&) = delete;
            CacheManager& operator=(const CacheManager&) = delete;

            // Simple in-memory map for demonstration.
            // In production, this would use a Redis client (e.g., hiredis or cpp_redis).
            std::map<std::string, std::pair<std::string, long long>> cache_; // value, expiration_timestamp
            std::mutex cache_mutex_;

            // Background thread for cleaning expired entries (simple example)
            void cleanupExpiredEntries();
            bool running_ = true;
            std::thread cleanup_thread_;
        };

        } // namespace Utils
        } // namespace Zenith

        #endif // ZENITH_CACHE_MANAGER_HPP
        ```
    *   Example `src/utils/cache_manager.cpp`:
        ```cpp
        #include "cache_manager.hpp"
        #include "logger.hpp"
        #include <chrono>
        #include <thread>
        #include <algorithm> // For std::remove_if

        namespace Zenith {
        namespace Utils {

        CacheManager& CacheManager::getInstance() {
            static CacheManager instance;
            return instance;
        }

        CacheManager::CacheManager() {
            // Start cleanup thread
            cleanup_thread_ = std::thread([this]() {
                cleanupExpiredEntries();
            });
            cleanup_thread_.detach(); // Detach to allow the main thread to exit
            LOG_INFO("CacheManager initialized. Cleanup thread started.");
        }

        void CacheManager::set(const std::string& key, const std::string& value, long ttl_seconds) {
            std::lock_guard<std::mutex> lock(cache_mutex_);
            long long expiration_time = 0;
            if (ttl_seconds > 0) {
                expiration_time = std::chrono::duration_cast<std::chrono::seconds>(
                    std::chrono::system_clock::now().time_since_epoch()
                ).count() + ttl_seconds;
            }
            cache_[key] = {value, expiration_time};
            LOG_DEBUG("Cached key '{0}' with TTL {1}s.", key, ttl_seconds);
        }

        std::optional<std::string> CacheManager::get(const std::string& key) {
            std::lock_guard<std::mutex> lock(cache_mutex_);
            auto it = cache_.find(key);
            if (it != cache_.end()) {
                long long current_time = std::chrono::duration_cast<std::chrono::seconds>(
                    std::chrono::system_clock::now().time_since_epoch()
                ).count();
                if (it->second.second == 0 || it->second.second > current_time) {
                    LOG_DEBUG("Cache hit for key '{0}'.", key);
                    return it->second.first;
                } else {
                    LOG_DEBUG("Cache miss for key '{0}' (expired).", key);
                    cache_.erase(it); // Remove expired entry
                }
            }
            LOG_DEBUG("Cache miss for key '{0}'.", key);
            return std::nullopt;
        }

        void CacheManager::remove(const std::string& key) {
            std::lock_guard<std::mutex> lock(cache_mutex_);
            if (cache_.erase(key) > 0) {
                LOG_DEBUG("Removed key '{0}' from cache.", key);
            }
        }

        void CacheManager::clear() {
            std::lock_guard<std::mutex> lock(cache_mutex_);
            cache_.clear();
            LOG_INFO("Cleared all cache entries.");
        }

        void CacheManager::cleanupExpiredEntries() {
            while (running_) {
                std::this_thread::sleep_for(std::chrono::seconds(30)); // Check every 30 seconds
                std::lock_guard<std::mutex> lock(cache_mutex_);
                long long current_time = std::chrono::duration_cast<std::chrono::seconds>(
                    std::chrono::system_clock::now().time_since_epoch()
                ).count();

                size_t initial_size = cache_.size();
                for (auto it = cache_.begin(); it != cache_.end(); ) {
                    if (it->second.second != 0 && it->second.second <= current_time) {
                        it = cache_.erase(it);
                    } else {
                        ++it;
                    }
                }
                if (cache_.size() < initial_size) {
                    LOG_INFO("Cache cleanup: removed {0} expired entries.", initial_size - cache_.size());
                }
            }
            LOG_INFO("CacheManager cleanup thread stopped.");
        }

        // To properly stop the cleanup thread on application shutdown, you'd need to set `running_ = false`
        // from a destructor or shutdown hook. For a quick demo, we'll omit explicit stop.

        } // namespace Utils
        } // namespace Zenith
        ```
*   **Rate Limiting**: `src/api/rate_limiter_middleware.hpp` is a placeholder for a middleware. A real implementation would use a client IP as a key and track request counts, potentially storing in Redis for distributed limiting.
    *   Example `src/api/rate_limiter_middleware.hpp` (conceptual):
        ```cpp
        #ifndef ZENITH_RATE_LIMITER_MIDDLEWARE_HPP
        #define ZENITH_RATE_LIMITER_MIDDLEWARE_HPP

        #include <httplib.h>
        #include <chrono>
        #include <map>
        #include <mutex>
        #include "../config/config.hpp"
        #include "../utils/logger.hpp"
        // In a real system, this would use Redis for distributed rate limiting

        namespace Zenith {
        namespace Api {

        // Simple in-memory rate limiter for demonstration.
        // In production, use Redis to handle distributed instances.
        class SimpleRateLimiter {
        public:
            static SimpleRateLimiter& getInstance() {
                static SimpleRateLimiter instance;
                return instance;
            }

            bool allowRequest(const std::string& client_ip) {
                std::lock_guard<std::mutex> lock(mutex_);
                auto now = std::chrono::steady_clock::now();
                auto& client_data = clients_[client_ip];

                // Remove requests older than the window
                client_data.requests.erase(
                    std::remove_if(client_data.requests.begin(), client_data.requests.end(),
                        [&](const std::chrono::steady_clock::time_point& timestamp) {
                            return std::chrono::duration_cast<std::chrono::seconds>(now - timestamp).count() > window_seconds_;
                        }),
                    client_data.requests.end());

                if (client_data.requests.size() < max_requests_) {
                    client_data.requests.push_back(now);
                    return true;
                }
                return false;
            }

        private:
            SimpleRateLimiter() :
                max_requests_(Config::AppConfig::getInstance().getMaxRequestsPerMinute()),
                window_seconds_(Config::AppConfig::getInstance().getRateLimitWindowSeconds()) {}
            SimpleRateLimiter(const SimpleRateLimiter&) = delete;
            SimpleRateLimiter& operator=(const SimpleRateLimiter&) = delete;

            struct ClientData {
                std::vector<std::chrono::steady_clock::time_point> requests;
            };

            std::map<std::string, ClientData> clients_;
            std::mutex mutex_;
            int max_requests_;
            int window_seconds_;
        };


        inline httplib::Server::Handler rateLimiterMiddleware(const httplib::Server::Handler& handler) {
            return [handler](const httplib::Request& req, httplib::Response& res) {
                if (!SimpleRateLimiter::getInstance().allowRequest(req.remote_addr)) {
                    res.status = 429; // Too Many Requests
                    res.set_header("Retry-After", std::to_string(Config::AppConfig::getInstance().getRateLimitWindowSeconds()));
                    res.set_content("{\"message\": \"Too Many Requests. Please try again later.\"}", "application/json");
                    LOG_WARN("Rate limit exceeded for IP: {0}", req.remote_addr);
                    return;
                }
                handler(req, res);
            };
        }

        } // namespace Api
        } // namespace Zenith

        #endif // ZENITH_RATE_LIMITER_MIDDLEWARE_HPP
        ```
    *   To integrate `rateLimiterMiddleware` into `routes.cpp`, you would wrap your handlers similar to `authMiddleware`:
        ```cpp
        // Example with both auth and rate limiting
        svr.Get("/users/me", rateLimiterMiddleware(authMiddleware([](const httplib::Request& req, httplib::Response& res) {
            // ... handler logic ...
        })));
        ```

