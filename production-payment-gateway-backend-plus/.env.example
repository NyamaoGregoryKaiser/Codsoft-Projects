```dotenv
# Application Configuration
NODE_ENV=development
PORT=3000
CORS_ORIGIN=* # In production, restrict to your frontend domain: http://localhost:3001,http://your-frontend.com

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=password
DB_NAME=payment_db

# JWT Configuration
JWT_SECRET=supersecretjwtkey # CHANGE THIS IN PRODUCTION
JWT_EXPIRES_IN=1h

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per IP per window

# External Payment Gateway API (Mocks for this project)
MOCK_PAYMENT_GATEWAY_API_URL=http://mock-gateway.com/api
MOCK_PAYMENT_GATEWAY_API_KEY=mock-api-key-123

# Webhook Configuration
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=60000 # 1 minute
```