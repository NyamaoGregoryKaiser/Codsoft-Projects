```
NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=epm_user
DB_PASSWORD=epm_password
DB_DATABASE=epm_db

JWT_SECRET=supersecretjwtkey
JWT_EXPIRES_IN=1h

REDIS_HOST=localhost # Not strictly used with node-cache, but for future Redis integration
REDIS_PORT=6379

CACHE_TTL=300 # Time to Live for cache entries in seconds (e.g., 5 minutes)
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX=100 # Max 100 requests per minute per IP
```