# Flask Configuration
FLASK_APP=wsgi.py
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000
FLASK_DEBUG=1 # Set to 0 in production
FLASK_CONFIG=development # development, testing, production

# Application Secrets
SECRET_KEY=your_flask_app_secret_key_change_me
JWT_SECRET_KEY=your_jwt_secret_key_change_me

# Database Configuration (PostgreSQL)
DB_HOST=db
DB_PORT=5432

# Development Database
DEV_DATABASE_URL=postgresql://projectflow_user:projectflow_password@db:5432/projectflow_dev_db
# Production Database (Example, update for your production environment)
# DATABASE_URL=postgresql://prod_user:prod_password@your_prod_db_host:5432/projectflow_prod_db

# Testing Database
TEST_DATABASE_URL=postgresql://projectflow_test_user:projectflow_test_password@db:5432/projectflow_test_db

# Redis Configuration (for Caching and Rate Limiting)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0 # Database 0 for general cache, 1 for rate limiting if separated

# Logging
LOG_LEVEL=DEBUG # DEBUG, INFO, WARNING, ERROR, CRITICAL
```