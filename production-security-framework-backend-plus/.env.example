```
# Application Configuration
FLASK_APP=manage.py
FLASK_ENV=development
SECRET_KEY="your_super_secret_key_here_for_flask_session_cookies_and_other_stuff"
DEBUG=True

# Database Configuration
DATABASE_URL="postgresql://user:password@db:5432/blog_db"

# JWT Configuration
JWT_SECRET_KEY="your_jwt_super_secret_key_here"
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600 # 1 hour
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30 # 30 days

# Redis Configuration (for Cache and Rate Limiter)
REDIS_URL="redis://redis:6379/0"

# CORS Configuration
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000" # Comma-separated list of allowed origins

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log

# Docker Specifics (if not using docker-compose.yml directly for these)
# Example: If running a single container
# DB_HOST=localhost
# DB_PORT=5432
# REDIS_HOST=localhost
# REDIS_PORT=6379
```