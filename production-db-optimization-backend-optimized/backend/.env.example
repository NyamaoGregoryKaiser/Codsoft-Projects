```ini
# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=9080
SERVER_THREADS=4

# Database Configuration (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_NAME=cppdboptimizer_db
DB_USER=user
DB_PASSWORD=password
DB_POOL_SIZE=5

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_characters_long
JWT_ISSUER=cppdboptimizer

# Logging Configuration
LOG_LEVEL=info # trace, debug, info, warn, error, critical, off
LOG_FILE_PATH=./logs/app.log

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per IP
RATE_LIMIT_WINDOW_SECONDS=60 # Within this window (in seconds)
```