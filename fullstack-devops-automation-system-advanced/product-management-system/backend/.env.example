# Backend Environment Variables
# Copy this file to .env and fill in actual values.

NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=productuser
DB_PASSWORD=productpassword
DB_NAME=productdb

# JWT Configuration
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandominproduction
JWT_EXPIRATION_DAYS=7d # e.g., '1h', '7d', '30m'

# Redis Configuration for Caching
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SECONDS=300 # Time-to-live for cache entries in seconds (5 minutes)

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000 # 1 minute window for rate limiting
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per window
```

