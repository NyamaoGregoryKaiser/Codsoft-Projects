# Docker Compose Variables
# These variables are used by docker-compose.yml to set up services
# Copy this file to .env and fill in actual values for local development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=productuser
DB_PASSWORD=productpassword
DB_NAME=productdb

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend Configuration (Node.js/Express)
BACKEND_PORT=5000
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandominproduction
JWT_EXPIRATION_DAYS=7d # e.g., '1h', '7d', '30m'
CACHE_TTL_SECONDS=300 # Time-to-live for cache entries in seconds (5 minutes)
RATE_LIMIT_WINDOW_MS=60000 # 1 minute window for rate limiting
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per window

# Frontend Configuration (React)
FRONTEND_PORT=3000
# REACT_APP_API_BASE_URL will be set by Dockerfile args or docker-compose environment
# For local React development outside Docker, you'd set it directly in frontend/.env
# REACT_APP_API_BASE_URL=http://localhost:5000/api/v1
