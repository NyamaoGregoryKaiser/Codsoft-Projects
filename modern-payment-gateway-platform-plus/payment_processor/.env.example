# FastAPI Application Settings
PROJECT_NAME="PaymentProcessorAPI"
APP_VERSION="1.0.0"
API_V1_STR="/api/v1"
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE_REPLACE_ME_IN_PRODUCTION" # Generate a strong random string
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours (for this example, in production might be shorter)
ALGORITHM="HS256"

# Database Configuration (PostgreSQL)
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=payment_processor_db
POSTGRES_TEST_DB=payment_processor_test_db

# Redis Configuration
REDIS_SERVER=redis
REDIS_PORT=6379
REDIS_DB=0 # For caching and rate limiting

# Celery Configuration (uses Redis for broker and backend)
CELERY_BROKER_URL="redis://redis:6379/1"
CELERY_RESULT_BACKEND="redis://redis:6379/2"
CELERY_MAX_RETRIES=5
CELERY_RETRY_DELAY_SECONDS=60 # Seconds between retries

# CORS Origins (comma-separated list of URLs)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"] # Example for dev, replace with prod origins

# Logging Configuration
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH="logs/app.log"
LOG_FORMAT="json" # or "plain"

# Admin User Defaults for seeding
FIRST_SUPERUSER_EMAIL="admin@example.com"
FIRST_SUPERUSER_PASSWORD="SecureAdminPassword123" # CHANGE THIS IN PRODUCTION!
```

#### `payment_processor/Dockerfile`
```dockerfile