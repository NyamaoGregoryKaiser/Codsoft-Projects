```
# Application Configuration
API_HOST=0.0.0.0
API_PORT=9080
API_THREADS=4

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@db:5432/scraper_db
DATABASE_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_characters_long
JWT_EXPIRES_IN_MINUTES=120 # Token expiration in minutes

# Logging Configuration
LOG_LEVEL=info # debug, info, warn, error, critical
LOG_FILE_PATH=logs/scraper_app.log
LOG_FILE_MAX_SIZE_MB=5
LOG_FILE_MAX_FILES=3

# Caching (Conceptual for this example, would use Redis or similar)
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300 # Time to live for cache entries

# Rate Limiting (Conceptual for this example)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
```