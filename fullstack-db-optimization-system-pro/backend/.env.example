```dotenv
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# PostgreSQL for the Optimizer Dashboard itself
DB_DIALECT=postgres
DB_HOST=localhost # or 'db' if using docker-compose
DB_PORT=5432
DB_NAME=optimizer_db
DB_USER=optimizer_user
DB_PASSWORD=optimizer_password

# JWT
JWT_SECRET=supersecretjwtkey
JWT_EXPIRES_IN=1h

# Redis
REDIS_URL=redis://localhost:6379 # or 'redis://redis:6379' if using docker-compose
```