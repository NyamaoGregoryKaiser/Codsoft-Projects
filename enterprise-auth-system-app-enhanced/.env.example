# FastAPI Application Settings
PROJECT_NAME="AuthSys API"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost"] # Adjust in production
LOG_LEVEL="INFO"

# JWT Settings
SECRET_KEY="supersecretjwtkey_replace_me_in_production" # Use a strong, random key in production!
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080 # 7 days (60*24*7)

# Database Settings
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=authsys_db
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname # Uncomment and set if you don't want to use default env vars above

# Redis Settings (for caching and rate limiting)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Superuser Initial Credentials (for initial setup)
FIRST_SUPERUSER_EMAIL="admin@example.com"
FIRST_SUPERUSER_PASSWORD="supersecretpassword"
FIRST_SUPERUSER_FIRST_NAME="Admin"
FIRST_SUPERUSER_LAST_NAME="System"

# Frontend URLs for email actions
FRONTEND_RESET_PASSWORD_URL="http://localhost:3000/reset-password"
FRONTEND_VERIFY_EMAIL_URL="http://localhost:3000/verify-email"
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
```