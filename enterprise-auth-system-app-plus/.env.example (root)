```
# General Application Settings
APP_NAME="SecureAuthService"
ENV="development" # development, testing, production

# FastAPI Backend Settings
SECRET_KEY="YOUR_SUPER_SECRET_KEY_GOES_HERE_CHANGE_ME_IN_PRODUCTION"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_DB_ENABLED=true # Set to false to rely solely on client-side refresh logic and token expiration

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin_password"

# PostgreSQL Database Settings
DB_HOST="db" # Docker service name
DB_PORT="5432"
DB_USER="user"
DB_PASSWORD="password"
DB_NAME="secureauth_db" # Main database
TEST_DB_NAME="test_db" # Database for tests

# Redis Settings
REDIS_HOST="redis" # Docker service name
REDIS_PORT="6379"

# React Frontend Settings
# This needs to match the Nginx proxy_pass config for /api/
REACT_APP_API_BASE_URL=http://localhost:80/api/v1
# During local development, without Nginx, this might be: http://localhost:8000/api/v1
```