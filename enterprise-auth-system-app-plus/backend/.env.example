```
# Application
APP_NAME="SecureAuthService"
ENV="development" # development, testing, production
SECRET_KEY="YOUR_SUPER_SECRET_KEY_GOES_HERE_CHANGE_ME_IN_PRODUCTION"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_DB_ENABLED=true # Set to false to rely solely on client-side refresh logic and token expiration
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin_password"

# Database
DB_HOST="db"
DB_PORT="5432"
DB_USER="user"
DB_PASSWORD="password"
DB_NAME="secureauth_db"

# Redis
REDIS_HOST="redis"
REDIS_PORT="6379"
```