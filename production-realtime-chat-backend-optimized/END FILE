    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Setup Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18'
          cache: 'npm'
          cache-dependency-path: backend/package-lock.json

      - name: Install Backend Dependencies
        run: npm install
        working-directory: ./backend

      - name: Run Backend Tests
        run: npm test -- --coverage
        working-directory: ./backend
        env:
          NODE_ENV: test
          # Provide dummy env vars for tests, or use a test specific .env
          DB_DIALECT: postgres
          DB_HOST: localhost
          DB_PORT: 5432
          DB_USER: testuser
          DB_PASSWORD: testpassword
          DB_NAME: chatdb_test
          JWT_SECRET: testsecret
          REDIS_HOST: localhost
          REDIS_PORT: 6379

      - name: Archive Backend Test Report
        uses: actions/upload-artifact@v3
        if: always()
        with:
          name: backend-test-report
          path: backend/coverage/lcov.info

  frontend-ci:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Setup Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18'
          cache: 'npm'
          cache-dependency-path: frontend/package-lock.json

      - name: Install Frontend Dependencies
        run: npm install
        working-directory: ./frontend

      - name: Run Frontend Tests
        run: npm test -- --coverage --watchAll=false # --watchAll=false for CI
        working-directory: ./frontend
        env:
          # Provide dummy env vars for tests
          REACT_APP_API_BASE_URL: http://localhost:5000/v1
          REACT_APP_SOCKET_URL: http://localhost:5000

      - name: Build Frontend
        run: npm run build
        working-directory: ./frontend
        env:
          REACT_APP_API_BASE_URL: http://localhost:5000/v1
          REACT_APP_SOCKET_URL: http://localhost:5000

      - name: Archive Frontend Build
        uses: actions/upload-artifact@v3
        with:
          name: frontend-build
          path: frontend/build

  deploy:
    runs-on: ubuntu-latest
    needs: [backend-ci, frontend-ci]
    if: github.ref == 'refs/heads/main' # Only deploy on push to main
    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Log in to Docker Hub
        uses: docker/login-action@v2
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      - name: Build and Push Backend Docker image
        uses: docker/build-push-action@v4
        with:
          context: ./backend
          file: ./backend/Dockerfile
          push: true
          tags: your-dockerhub-username/chat-app-backend:latest
          build-args: |
            NODE_ENV=production
          cache-from: type=gha,scope=backend
          cache-to: type=gha,mode=max,scope=backend

      - name: Build and Push Frontend Docker image
        uses: docker/build-push-action@v4
        with:
          context: ./frontend
          file: ./frontend/Dockerfile
          push: true
          tags: your-dockerhub-username/chat-app-frontend:latest
          build-args: |
            REACT_APP_API_BASE_URL=${{ secrets.PROD_API_BASE_URL }}
            REACT_APP_SOCKET_URL=${{ secrets.PROD_SOCKET_URL }}
          cache-from: type=gha,scope=frontend
          cache-to: type=gha,mode=max,scope=frontend

      - name: Deploy to Server via SSH
        uses: appleboy/ssh-action@v0.1.10
        with:
          host: ${{ secrets.SSH_HOST }}
          username: ${{ secrets.SSH_USERNAME }}
          key: ${{ secrets.SSH_KEY }}
          script: |
            cd /path/to/your/chat-app-project # Your project directory on the server
            # Pull latest code or just ensure docker-compose.yml is updated
            # For this example, we're building and pushing images, so just need to pull images and restart
            docker-compose pull
            docker-compose up -d --remove-orphans
            docker image prune -f # Clean up old images

