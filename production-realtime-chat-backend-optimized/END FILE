### 3. Configuration & Setup

#### `docker-compose.yml`

This file orchestrates the backend, PostgreSQL database, and Redis cache.

```yaml
version: '3.8'

services:
  db:
    image: postgres:15-alpine
    container_name: chat_db
    environment:
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: ${DB_NAME}
    ports:
      - "5432:5432"
    volumes:
      - chat_db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 5s
      timeout: 5s
      retries: 5
    restart: always

  redis:
    image: redis:7-alpine
    container_name: chat_redis
    ports:
      - "6379:6379"
    command: redis-server --appendonly yes --requirepass ${REDIS_PASSWORD} # Require password in production
    volumes:
      - chat_redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "--raw", "INFO"] # if using password, add -a ${REDIS_PASSWORD}
      interval: 5s
      timeout: 5s
      retries: 5
    restart: always

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: chat_backend
    ports:
      - "5000:5000"
    environment:
      NODE_ENV: ${NODE_ENV}
      PORT: 5000
      FRONTEND_URL: ${FRONTEND_URL}
      DB_DIALECT: postgres
      DB_HOST: db
      DB_PORT: 5432
      DB_USER: ${DB_USER}
      DB_PASSWORD: ${DB_PASSWORD}
      DB_NAME: ${DB_NAME}
      JWT_SECRET: ${JWT_SECRET}
      JWT_ACCESS_EXPIRATION_MINUTES: ${JWT_ACCESS_EXPIRATION_MINUTES}
      JWT_REFRESH_EXPIRATION_DAYS: ${JWT_REFRESH_EXPIRATION_DAYS}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD}
      RATE_LIMIT_WINDOW_MS: ${RATE_LIMIT_WINDOW_MS}
      RATE_LIMIT_MAX_REQUESTS: ${RATE_LIMIT_MAX_REQUESTS}
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    volumes:
      - ./backend:/app
      - /app/node_modules # Avoid overwriting node_modules inside container
    # command: bash -c "npm install && npm run migrate && npm run seed && npm run dev" # For dev with automatic migrations/seeds
    command: bash -c "npm install && npm run migrate && npm start" # For production, run migrations and start
    restart: always

  # Frontend service can be served statically or via another container
  # For local development, typically run 'npm start' in frontend directory
  # For production, build and serve with Nginx or a simple HTTP server
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: chat_frontend
    ports:
      - "3000:3000" # Or 80 for production serve
    environment:
      REACT_APP_API_BASE_URL: http://localhost:5000/v1 # This is internal for docker or external if host network used.
      REACT_APP_SOCKET_URL: http://localhost:5000
    volumes:
      - ./frontend:/app
      - /app/node_modules
    command: npm start # For dev
    # command: npm run build && serve -s build -l 3000 # For production
    depends_on:
      - backend

volumes:
  chat_db_data:
  chat_redis_data:
```

