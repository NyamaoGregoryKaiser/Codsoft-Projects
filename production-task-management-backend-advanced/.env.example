# Backend Environment Variables (will be copied to backend/.env inside container)
POSTGRES_SERVER=db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=task_db
SECRET_KEY="YOUR_SUPER_SECRET_KEY_CHANGE_ME_PLEASE"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_EXPIRE_SECONDS=60
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=adminpassword
APP_NAME="Task Management System"
API_V1_STR=/api/v1
DEBUG=True
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost"] # Add more origins as needed

# Frontend Environment Variables
REACT_APP_API_BASE_URL=http://localhost:80/api/v1