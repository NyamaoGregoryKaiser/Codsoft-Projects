```dotenv
NODE_ENV=development
PORT=5000

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/payment_processor_db"
TEST_DATABASE_URL="postgresql://user:password@localhost:5433/payment_processor_test_db"

# JWT Secret
JWT_SECRET="supersecretjwtkeythatshouldbeverylongandrandomforproduction"
JWT_EXPIRES_IN="1h"

# Mock Payment Gateway
MOCK_PAYMENT_GATEWAY_URL="http://localhost:5001/mock-payment" # If you build a separate mock service
MOCK_PAYMENT_GATEWAY_API_KEY="mock_api_key_123"

# Cache Configuration (in seconds)
CACHE_DURATION_SECONDS=300

# Rate Limiting (per windowMs)
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per minute
```