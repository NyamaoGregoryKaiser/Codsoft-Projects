```ini
# Environment variables for the backend application
# Rename this file to .env and fill in actual values for production.

# --- Database Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mobile_app_db
DB_USER=appuser
DB_PASSWORD=secure_password

# --- Application Configuration ---
APP_PORT=8080
JWT_SECRET=super_secret_jwt_key_that_is_at_least_32_characters_long
LOG_LEVEL=info # trace, debug, info, warn, error, critical, off

# --- Caching Configuration ---
CACHE_TTL_SECONDS=300 # Time-to-live for cached items in seconds

# --- Rate Limiting Configuration ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BUCKET_CAPACITY=100 # Max requests in a bucket
RATE_LIMIT_BUCKET_REFILL_RATE=10 # Requests per second
```