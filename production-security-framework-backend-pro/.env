```
# --- CORE APPLICATION SETTINGS ---
APP_NAME="Secure Task Management"
ENVIRONMENT="development" # development, testing, production
SECRET_KEY="your-super-secret-key-replace-me-in-production-with-a-long-random-string-like-os.urandom(32).hex()"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=43200 # 30 days

# --- DATABASE SETTINGS ---
POSTGRES_SERVER=db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=secure_task_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:5432/${POSTGRES_DB}

# --- REDIS SETTINGS (for Caching & Rate Limiting) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- CORS SETTINGS ---
BACKEND_CORS_ORIGINS='http://localhost:3000,http://localhost:8080' # Comma-separated list of origins, e.g., 'http://localhost:3000,https://your-domain.com'

# --- LOGGING SETTINGS ---
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- INITIAL ADMIN USER (for seeding) ---
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="admin_password" # CHANGE THIS IN PRODUCTION
```