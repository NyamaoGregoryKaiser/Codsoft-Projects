APP_PORT=8080
DB_HOST=db
DB_PORT=5432
DB_NAME=secure_app_db
DB_USER=admin
DB_PASSWORD=secretpassword

JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandom
