# Server Configuration
PORT=3000

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mydb" # Update with your DB credentials

# JWT Configuration
JWT_SECRET="your_secret_key_here_at_least_32_characters" # CHANGE THIS IN PRODUCTION!
JWT_EXPIRATION_TIME="1h"

# Logging Configuration
LOG_LEVEL="info" # debug, info, warn, error

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS="60000"       # 1 minute in milliseconds
RATE_LIMIT_MAX_REQUESTS="100"      # Max 100 requests per window

# Caching Configuration (in seconds)
CACHE_TTL="300" # 5 minutes