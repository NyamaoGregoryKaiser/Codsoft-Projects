{
    "app": {
        "port": 8080,
        "document_root": "./static",
        "log_path": "./logs",
        "log_file": "cms.log",
        "server_header": "CMS-CPP/1.0",
        "idle_timeout": 60,
        "keepalive_requests": 0
    },
    "db": {
        "client_type": "postgresql",
        "host": "postgres",
        "port": 5432,
        "user": "cms_user",
        "password": "cms_password",
        "database": "cms_db",
        "auto_reconnect": true,
        "connections_number": 10
    },
    "jwt": {
        "secret": "supersecretjwtkeythatshouldbeverylongandrandom",
        "expires_in_seconds": 3600,
        "refresh_token_expires_in_seconds": 604800
    },
    "rate_limit": {
        "max_requests": 100,
        "window_seconds": 60
    },
    "cache": {
        "enabled": true,
        "default_ttl_seconds": 300
    }
}