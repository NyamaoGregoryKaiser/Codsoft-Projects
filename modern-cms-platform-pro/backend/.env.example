# Django Settings
SECRET_KEY=your_super_secret_key_here_at_least_50_chars_long_and_random
DEBUG=True # Set to False in production
ALLOWED_HOSTS=localhost,127.0.0.1 # Comma-separated list for production

# Database (PostgreSQL)
DB_NAME=cms_dev_db
DB_USER=cms_dev_user
DB_PASSWORD=cms_dev_password
DB_HOST=db # 'db' is the service name in docker-compose
DB_PORT=5432

# Redis Cache
REDIS_URL=redis://redis:6379/1 # 'redis' is the service name in docker-compose

# CORS
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000 # Uncomment and set specific origins for production

# Production Security (only applies when DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
```

