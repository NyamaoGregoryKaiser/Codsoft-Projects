# Environment variables for Docker/CI/CD
# This file is for example and local development, production should use secure secrets management

# Database configuration
DB_HOST=db
DB_PORT=5432
DB_USER=cmsuser
DB_PASSWORD=cms_password
DB_NAME=cms_db

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Application configuration
HTTP_PORT=8080
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=super_secret_jwt_key_that_should_be_long_and_random_in_production

# Logging
LOG_PATH=logs/cms_backend.log
LOG_LEVEL=2 # 0:trace, 1:debug, 2:info, 3:warn, 4:error, 5:critical
```