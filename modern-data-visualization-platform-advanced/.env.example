```ini
# FastAPI Application Settings
PROJECT_NAME="VisuFlow"
API_VERSION="1.0.0"
API_V1_STR="/api/v1"

# IMPORTANT: Change this to a strong, random 32-character string for production!
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE_CHANGE_ME_PLEASE_32_CHARS"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# CORS origins - Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Database Configuration (PostgreSQL)
POSTGRES_SERVER=db # Service name in docker-compose
POSTGRES_USER=visuflow_user
POSTGRES_PASSWORD=visuflow_password
POSTGRES_DB=visuflow_db
DATABASE_URL="postgresql+asyncpg://visuflow_user:visuflow_password@db:5432/visuflow_db"

# Redis Configuration
REDIS_HOST=redis # Service name in docker-compose
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL="redis://redis:6379/0"

# Initial Superuser Credentials (for seeding)
FIRST_SUPERUSER_EMAIL=admin@visuflow.com
FIRST_SUPERUSER_PASSWORD=adminpassword! # IMPORTANT: Change in production

# Logging Configuration
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Testing Configuration
TESTING=False
DB_ECHO=False # Set to True to log SQL statements to console

# Caching Configuration
CACHE_EXPIRATION_SECONDS=300 # Default cache expiry for data in seconds (5 minutes)

# Rate Limiting
RATE_LIMIT_DEFAULT="10/minute" # Default limit for unauthenticated requests
RATE_LIMIT_AUTH="60/minute" # Limit for authenticated requests
```