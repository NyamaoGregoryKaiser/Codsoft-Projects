{
  "name": "dbtune-backend",
  "version": "1.0.0",
  "description": "DBTune Backend API for Database Optimization System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit --coverage",
    "migrate:make": "knex migrate:make --knexfile ./db/knexfile.js",
    "migrate:latest": "knex migrate:latest --knexfile ./db/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile ./db/knexfile.js",
    "seed:make": "knex seed:make --knexfile ./db/knexfile.js",
    "seed:run": "knex seed:run --knexfile ./db/knexfile.js"
  },
  "keywords": [],
  "author": "AI Assistant",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "node-cache": "^5.1.2",
    "pg": "^8.11.5",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "collectCoverageFrom": [
      "src/server/**/*.js",
      "!src/server/db/migrations/*.js",
      "!src/server/db/seeds/*.js",
      "!src/server/app.js",
      "!src/server/server.js",
      "!src/server/config/*.js"
    ]
  }
}