```ini
# Core Application Settings
APP_NAME="E-commerce System"
APP_DESCRIPTION="A comprehensive e-commerce platform built with FastAPI."
APP_VERSION="1.0.0"

# Database Settings
DATABASE_URL="postgresql+asyncpg://user:password@db:5432/ecommerce_db"
# Example for local development without Docker:
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/ecommerce_db"

# Security Settings
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE_CHANGE_THIS_IN_PRODUCTION"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin User Credentials (for initial setup or testing)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin_password"

# Caching
# REDIS_URL="redis://redis:6379/0" # Uncomment and configure if using Redis for caching/rate-limiting
# CACHE_TTL_SECONDS=300 # Default TTL for cached responses

# Logging
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Rate Limiting
# RATE_LIMIT_ENABLED="True" # Set to True to enable rate limiting middleware
# RATE_LIMIT_RULES="5/minute,100/hour" # Example: 5 requests per minute, 100 per hour
```