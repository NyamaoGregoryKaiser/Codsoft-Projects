NODE_ENV=development
PORT=3000
SECRET_KEY=supersecretjwtkeythatshouldbeverylongandcomplexinproduction
REFRESH_SECRET_KEY=anothersecretkeyforrefresh
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=horizon_pms_db
# For testing, you might use a separate database
DB_TEST_NAME=horizon_pms_test_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100