{
  "name": "web-scraping-tools-backend",
  "version": "1.0.0",
  "description": "Backend for a comprehensive web scraping tools system",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --detectOpenHandles --coverage --testTimeout=10000",
    "test:watch": "jest --watch --testTimeout=10000",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo",
    "seed": "sequelize db:seed:all",
    "db:reset": "sequelize db:drop && sequelize db:create && npm run migrate && npm run seed"
  },
  "keywords": [],
  "author": "AI Assistant",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.4",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "http-status": "^1.7.4",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "puppeteer": "^22.7.1",
    "redis": "^4.6.14",
    "sequelize": "^6.37.3",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/src/config/",
      "/src/db/migrations/",
      "/src/db/seeders/",
      "/src/app.js",
      "/src/server.js"
    ]
  }
}