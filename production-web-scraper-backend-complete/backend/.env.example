NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=scraping_db
# DATABASE_URL=postgres://user:password@host:port/database # For external DB like Heroku, overrides above

# JWT Secret
JWT_SECRET=a_very_long_and_complex_secret_key_for_jwt_tokens_that_is_at_least_32_characters_long
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30 # Not fully implemented for simplicity, but good practice

# Redis Configuration (for BullMQ and Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Puppeteer Configuration
PUPPETEER_HEADLESS=new # Set to false for debugging browser UI, 'new' for new headless mode
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# Frontend Configuration
REACT_APP_API_BASE_URL=http://localhost:5000/api