# Core Application Settings
APP_NAME="WebScrapingSystem"
ENVIRONMENT="development"
DEBUG="True"
SECRET_KEY="YOUR_SUPER_SECRET_JWT_KEY_HERE_MIN_32_CHARS" # IMPORTANT: Generate a strong random key!
ACCESS_TOKEN_EXPIRE_MINUTES="60"

# Database Settings
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="scraper_db"
POSTGRES_HOST="db"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis Settings (for Celery, Cache, Rate Limiting)
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}/0" # For fastapi-cache2 and fastapi-limiter
CELERY_BROKER_URL="redis://${REDIS_HOST}:${REDIS_PORT}/1" # Celery broker
CELERY_RESULT_BACKEND="redis://${REDIS_HOST}:${REDIS_PORT}/2" # Celery result backend

# Admin User Seed Data (for initial setup)
FIRST_SUPERUSER_EMAIL="admin@example.com"
FIRST_SUPERUSER_PASSWORD="supersecretpassword"
```
