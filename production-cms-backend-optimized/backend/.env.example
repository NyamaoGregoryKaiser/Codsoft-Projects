```dotenv
# Application Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=cms_user
DB_PASSWORD=cms_password
DB_NAME=cms_db
# Set to 'true' if your PostgreSQL requires SSL connection (e.g., in production with managed DBs)
DB_SSL=false

# Test Database Configuration
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=cms_test_user
TEST_DB_PASSWORD=cms_test_password
TEST_DB_NAME=cms_test_db

# JWT Configuration
JWT_SECRET=supersecretjwtkey
JWT_EXPIRATION=1d # e.g., 1h, 24h, 7d

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379
CACHE_DURATION_SECONDS=3600 # 1 hour

# Logging Configuration
LOG_LEVEL=info # error, warn, info, http, verbose, debug, silly
```