```
# --- Core Application Settings ---
PROJECT_NAME="Realtime Chat App"
API_VERSION="1.0.0"
API_V1_STR="/api/v1"

# --- Database Settings (PostgreSQL) ---
POSTGRES_SERVER="db"
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="chat_db"
POSTGRES_PORT=5432
# DATABASE_URL="postgresql+asyncpg://user:password@db:5432/chat_db" # Optional: Can be set manually or generated

# --- Redis Settings ---
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD="" # Optional: If your Redis requires a password
# REDIS_URL="redis://:password@redis:6379/0" # Optional: Can be set manually or generated

# --- JWT Authentication Settings ---
SECRET_KEY="your_super_secret_key_change_me_in_production" # IMPORTANT: Change this to a strong, random key
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 7 days (60 * 24 * 7)

# --- Logging Settings ---
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- Rate Limiting Settings ---
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# --- Frontend Settings ---
FRONTEND_URL="http://localhost:3000"

# --- Docker Compose Specific ---
# These are typically set inside Docker Compose environment section
# REACT_APP_API_BASE_URL="http://localhost:8000/api/v1"
# REACT_APP_API_WS_BASE_URL="ws://localhost:8000/api/v1"
```