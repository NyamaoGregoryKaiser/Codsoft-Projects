NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=password
DB_DATABASE=auth_db

# JWT Configuration
JWT_SECRET=supersecretjwtkey
JWT_ACCESS_EXPIRATION=15m # e.g., 15m, 1h, 7d
JWT_REFRESH_SECRET=anothersupersecretrefreshkey
JWT_REFRESH_EXPIRATION=7d # e.g., 7d, 30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per IP per window

# Logging
LOG_LEVEL=info # debug, info, warn, error