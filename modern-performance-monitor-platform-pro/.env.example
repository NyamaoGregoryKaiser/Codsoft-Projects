# Flask application settings
FLASK_APP=app
FLASK_ENV=development # Set to 'production' for deployment
SECRET_KEY='your_super_secret_key_for_flask_sessions_and_security'

# Database configuration
DATABASE_URL=postgresql://user:password@localhost:5432/synapse_sense_db
# For Docker, use: postgresql://user:password@db:5432/synapse_sense_db

# Redis configuration for Caching and Rate Limiting
REDIS_URL=redis://localhost:6379/0
# For Docker, use: redis://redis:6379/0

# Worker settings
WORKER_INTERVAL_SECONDS=60 # How often the worker checks monitors

# Logging
LOG_TO_STDOUT=True
LOG_FILE=synapse_sense.log
LOG_LEVEL=INFO

# Test database (if running tests locally outside of Docker)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/synapse_sense_test_db

# Admin user for initial seeding
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@synapsesense.com
ADMIN_PASSWORD=adminpassword
```